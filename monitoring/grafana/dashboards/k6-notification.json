{
  "uid": "k6-notification",
  "title": "k6 — Notification Service Load Test",
  "tags": ["k6", "load-testing"],
  "refresh": "5s",
  "schemaVersion": 39,
  "time": { "from": "now-15m", "to": "now" },
  "timezone": "browser",
  "graphTooltip": 1,
  "panels": [
    {
      "id": 1,
      "title": "Virtual Users",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "#5794F2" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": { "legend": { "displayMode": "hidden" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "k6_vus",
          "legendFormat": "VUs",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Requests / sec",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "fixed", "fixedColor": "#73BF69" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": { "legend": { "displayMode": "hidden" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(k6_http_reqs_total[30s])",
          "legendFormat": "RPS",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Error Rate",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": { "mode": "fixed", "fixedColor": "#F2495C" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.01 }
            ]
          }
        }
      },
      "options": { "legend": { "displayMode": "hidden" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(k6_http_req_failed_total[30s]) / rate(k6_http_reqs_total[30s])",
          "legendFormat": "Error %",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Global Response Time (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 7 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 2 }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "right" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(k6_http_req_duration_bucket[30s])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(k6_http_req_duration_bucket[30s])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(k6_http_req_duration_bucket[30s])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "id": 5,
      "title": "POST /send — Response Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 15 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 300 },
              { "color": "red", "value": 500 }
            ]
          }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(k6_post_send_duration_bucket[30s])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(k6_post_send_duration_bucket[30s])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(k6_post_send_duration_bucket[30s])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "id": 6,
      "title": "GET /{id} — Response Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 15 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 300 },
              { "color": "red", "value": 500 }
            ]
          }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(k6_get_by_id_duration_bucket[30s])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(k6_get_by_id_duration_bucket[30s])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(k6_get_by_id_duration_bucket[30s])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "id": 7,
      "title": "GET /?user_id= — Response Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 15 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 300 },
              { "color": "red", "value": 500 }
            ]
          }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(k6_list_by_user_duration_bucket[30s])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(k6_list_by_user_duration_bucket[30s])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(k6_list_by_user_duration_bucket[30s])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "id": 8,
      "title": "404 Rate (multi-worker routing misses)",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 23 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "fixed", "fixedColor": "#FF9830" },
          "custom": { "lineWidth": 2, "fillOpacity": 5 }
        }
      },
      "options": { "legend": { "displayMode": "hidden" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(k6_notification_404_count_total[30s])",
          "legendFormat": "404/s",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "title": "Dropped Iterations",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 23 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "#A352CC" },
          "custom": { "lineWidth": 2, "fillOpacity": 5 }
        }
      },
      "options": { "legend": { "displayMode": "hidden" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(k6_dropped_iterations_total[30s])",
          "legendFormat": "dropped/s",
          "refId": "A"
        }
      ]
    }
  ]
}
