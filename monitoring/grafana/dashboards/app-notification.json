{
  "uid": "app-notification",
  "title": "Notification System \u2014 Live Dashboard",
  "tags": [
    "notification",
    "app",
    "k6"
  ],
  "refresh": "5s",
  "schemaVersion": 38,
  "time": {
    "from": "now-15m",
    "to": "now"
