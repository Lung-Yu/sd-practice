    {
      "id": 11,
      "title": "Delivery Rate \u2014 SENT vs FAILED/s",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 19
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "stacking": {
              "mode": "none"
            }
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byNamePattern",
              "options": "FAILED.*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#F2495C"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byNamePattern",
              "options": "SENT.*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#73BF69"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(notifications_sent_total{status=\"SENT\"}[30s])) by (channel)",
          "legendFormat": "SENT \u2014 {{channel}}",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(notifications_sent_total{status=\"FAILED\"}[30s])) by (channel)",
          "legendFormat": "FAILED \u2014 {{channel}}",
          "refId": "B"
